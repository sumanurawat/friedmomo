{
  "name": "storyboarder",
  "private": true,
  "version": "0.1.0-beta",
  "description": "Storyboarder: turn any idea into a complete 3-act storyboard in 90 seconds. Local desktop app, bring your own OpenRouter key.",
  "homepage": "https://friedmomo.com",
  "author": {
    "name": "Friedmomo",
    "email": "hello@friedmomo.com",
    "url": "https://friedmomo.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sumanurawat/friedmomo.git"
  },
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "node server/index.js & vite --host 127.0.0.1 --port 4173 && kill %1",
    "dev:server": "node server/index.js",
    "dev:client": "vite --host 127.0.0.1 --port 4173",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "node --test",
    "electron:dev": "concurrently -k -r -n server,client,electron \"npm run dev:server\" \"npm run dev:client\" \"wait-on http://127.0.0.1:4173 && cross-env STORYBOARDER_ELECTRON_DEV=1 electron .\"",
    "electron:build": "npm run build && electron-builder --config build/electron-builder.yml",
    "electron:build:mac": "npm run build && electron-builder --mac --config build/electron-builder.yml",
    "electron:build:win": "npm run build && electron-builder --win --config build/electron-builder.yml",
    "electron:build:linux": "npm run build && electron-builder --linux --config build/electron-builder.yml",
    "release": "npm run build && electron-builder --config build/electron-builder.yml --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "uuid": "^13.0.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "vite": "^7.3.1",
    "wait-on": "^9.0.5"
  }
}
